# Network settings
TIMEOUT=180

# EODData API Key
EOD_API_KEY=your_api_key_here

# PostgreSQL connection settings
DB_HOST=localhost
DB_PORT=5432
DB_NAME=stocks
DB_USER=your_db_user
DB_PASS=your_db_password

# Optional: comma-separated list of exchange codes to sync (leave blank for all)
# Standard EXCHANGES=AMEX,CC,FOREX,INDEX,NASDAQ,NYSE,OTCBB
# Bronze EXCHANGES=AMEX,CC,FOREX,INDEX,NASDAQ,NYSE,OTCBB,SGX,NSE,TSX,TSXV,AMS,BRU,LIS,OSL,PAR
# Silver EXCHANGES=AMEX,CC,FOREX,INDEX,NASDAQ,NYSE,OTCBB,SGX,NSE,TSX,TSXV,AMS,BRU,LIS,OSL,PAR,ASX,LSE
# Gold EXCHANGES=AMEX,CC,FOREX,INDEX,NASDAQ,NYSE,OTCBB,SGX,NSE,TSX,TSXV,AMS,BRU,LIS,OSL,PAR,ASX,LSE,CFE,MGEX,NYBOT,WCE,EUREX,LIFFE,USMF
# Platinum EXCHANGES=AMEX,CC,FOREX,INDEX,NASDAQ,NYSE,OTCBB,SGX,NSE,TSX,TSXV,AMS,BRU,LIS,OSL,PAR,ASX,LSE,CFE,MGEX,NYBOT,WCE,EUREX,LIFFE,USMF,MSE,FRA,SHE,SHG
EXCHANGES=

# Quote interval to fetch ('d'=daily, 'w'=weekly, 'm'=monthly, etc.)
QUOTE_INTERVAL=d

# Number of days of quote history to fetch (0 = all available)
QUOTE_DAYS=0

# Maximum concurrent API workers
MAX_WORKERS=4

# Delay between API requests (seconds) to avoid rate limiting
REQUEST_DELAY=0.25

# App settings
DASH_HOST=127.0.0.1
DASH_DEBUG=true
PORT=8050